{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "vendor", "driver", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "shopId": { "type": "string" },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" }
      },
      "required": ["name", "price", "shopId"]
    },
    "Order": {
      "title": "Order",
      "description": "Order information",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "shopId": { "type": "string" },
        "shopName": { "type": "string" },
        "shopAddress": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "image": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "ready", "delivering", "completed", "rejected"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryFee": { "type": "number" },
        "commission": { "type": "number" },
        "vendorEarnings": { "type": "number" },
        "driverEarnings": { "type": "number" },
        "distanceKm": { "type": "number" },
        "appEarnings": { "type": "number" },
        "driverId": { "type": "string" }
      },
      "required": ["customerId", "shopId", "totalAmount", "status", "createdAt"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Shop information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "deliveryFee": { "type": "number" },
        "minimumOrder": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "address": { "type": "string" },
        "vendorId": { "type": "string" }
      },
      "required": ["name", "vendorId"]
    },
    "Category": {
      "title": "Category",
      "description": "Category information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available for purchase"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by customers"
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Shops available on the platform"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    }
  }
}
