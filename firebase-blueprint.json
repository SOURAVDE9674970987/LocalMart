{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (customer, vendor, or driver)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "vendor", "delivery"] },
        "profileImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Shop": {
      "title": "Shop",
      "description": "A vendor's shop",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string", "description": "UID of the vendor who owns this shop" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "deliveryFee": { "type": "number" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["vendorId", "name", "image"]
    },
    "Product": {
      "title": "Product",
      "description": "An item sold in a shop",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" }
      },
      "required": ["shopId", "name", "price", "image", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's order from a shop",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "shopId": { "type": "string" },
        "driverId": { "type": "string" },
        "items": { 
          "type": "array",
          "description": "Array of cart items with quantities"
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "preparing", "ready", "delivering", "completed"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "shopId", "items", "totalAmount", "status", "deliveryAddress"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Stores shop details"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores products belonging to shops"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores customer orders"
    }
  }
}
